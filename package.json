{
  "name": "@benvenker/agent-session-search",
  "version": "0.1.1",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benvenker/agent-session-search.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "agent-session-search": "dist/cli.js",
    "agent-session-search-doctor": "dist/fff-preflight.js",
    "agent-session-search-mcp": "dist/server.js"
  },
  "files": [
    "dist/*.js",
    "LICENSE",
    "scripts/postinstall.mjs",
    "README.md"
  ],
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "check:beads": "node scripts/check-beads-sync.mjs",
    "check:fff": "tsx src/fff-preflight.ts",
    "prepack": "npm run build",
    "postinstall": "node scripts/postinstall.mjs",
    "test": "vitest run",
    "smoke": "vitest run test/mcp-smoke.test.ts",
    "dev:mcp": "tsx src/server.ts",
    "dev:cli": "tsx src/cli.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastmcp": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
